# AI Voice Agent Environment Configuration

# JWT Configuration
JWT_SECRET_KEY=supersecretjwtkeyterratern2026voiceagentconfigchangeit

# Database Configuration
# Default pointing to local docker-hosted PostgreSQL
DATABASE_URL=postgresql://ai_user:ai_password@localhost:5432/ai_voice_agent

# OpenAI Configuration
# Add your API Key here to enable real STT/TTS and LLM capabilities.
# If empty, the system runs in Mock mode with realistic static responses.
OPENAI_API_KEY=

# Local Storage Paths
AUDIO_STORAGE_PATH=static/audio
DOCUMENT_STORAGE_PATH=static/documents
